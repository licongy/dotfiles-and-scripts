MEDIA_OPTS   = ["电影", "电视剧", "网剧", "短视频", "网络电影", "中剧", "竖屏短剧"]
CONTENT_OPTS = ["故事概要", "全剧大纲", "人物设定", "人物小传", "人物关系",
                 "分场大纲", "剧本", "项目介绍", "思考", "随笔", "小说", "其他"]
GENRE_OPTS   = ["爱情", "都市", "职场", "动作", "恐怖", "悬疑", "探案", "现实",
                 "古装", "穿越", "喜剧", "科幻", "奇幻", "武侠", "家庭", "历史"]

def get_episode_str(filename: str) -> Optional[str]:
    """从文件名末尾寻找 E 或 第 加数字的组合，并截取到末尾（不含扩展名）"""
    name_without_ext = os.path.splitext(filename)[0]
    matches = list(re.finditer(r'([E第e]\d+)', name_without_ext))
    if matches:
        return name_without_ext[matches[-1].start():]
    return None

def get_file_creation_date(file_path: str) -> str:
    """获取文件的创建日期"""
    try:
        ts = os.stat(file_path).st_ctime
    except Exception:
        ts = datetime.datetime.now().timestamp()
    return datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M:%S")

class FMData(TypedDict, total=False):
    storyMarkdown: str
    title: str
    media_type: str
    content_type: str
    genre: List[str]
    season: str
    episode: str
    author: List[str]
    created_date: str
    version: str
    tags: List[str]

def prompt_common_front_matter(source_path: str) -> FMData:
    """询问一次公共字段（所有文件共享）"""
    while True:
        info: FMData = {}

        info['storyMarkdown'] = "1.0"
        
        title = questionary.text("标题:").ask()
        if title is None: sys.exit(0)
        info['title'] = title.strip()

        media_type = questionary.select(
            "媒体类型:",
            choices=MEDIA_OPTS,
            default="电影"
        ).ask()
        if media_type is None: sys.exit(0)
        info['media_type'] = media_type

        content_type = questionary.select(
            "内容类型:",
            choices=CONTENT_OPTS,
            default="剧本"
        ).ask()
        if content_type is None: sys.exit(0)
        info['content_type'] = content_type

        genre = questionary.checkbox(
            "类型 (空格选中, 回车确认):",
            choices=GENRE_OPTS
        ).ask()
        if genre is None: sys.exit(0)
        info['genre'] = genre

        season = questionary.text(
            "季数:",
            validate=lambda text: True if (not text or text.isdigit()) else "季数必须是纯数字！"
        ).ask()
        if season is None: sys.exit(0)
        info['season'] = season.strip()
        
        info['episode'] = ""
        
        author_str = questionary.text("作者 (多个作者用逗号分隔):").ask()
        if author_str is None: sys.exit(0)
        info['author'] = [a.strip() for a in author_str.split(',')] if author_str.strip() else []

        info['created_date'] = get_file_creation_date(source_path)
        
        version = questionary.text("版本:").ask()
        if version is None: sys.exit(0)
        info['version'] = version.strip()
        
        tags_str = questionary.text("标签 (多个标签用逗号分隔):").ask()
        if tags_str is None: sys.exit(0)
        info['tags'] = [t.strip() for t in tags_str.split(',')] if tags_str.strip() else []

        print("\n=======  请确认以下公共信息（所有文件共享）  =======")
        for k, v in info.items():
            print(f"{k}: {v}")
        print("==============================================")
        
        confirm = questionary.confirm("确认无误？").ask()
        if confirm is None: sys.exit(0)
        if confirm:
            return info
        print(">> 重新填写 ...\n")

def build_front_matter(data: FMData) -> str:
    """把 dict 转为 YAML front-matter 字符串"""
    fm_lines: list[str] = ['---']
    for k, v in data.items():
        if v:
            if isinstance(v, list):
                fm_lines.append(f"{k}:")
                for item in v:
                    fm_lines.append(f"  - {item}")
            else:
                fm_lines.append(f"{k}: {v if v is not None else ''}")
    fm_lines.append('---\n\n')
    return '\n'.join(fm_lines)


def get_style_mapping(source_folder: str) -> str:
    """
    获取样式映射，优先级：
    1. 转换源目录 (source_folder) 下的 style.toml
    2. 脚本所在目录下的 style.toml
    3. 默认硬编码映射
    """
    default_mapping = (
        "r[style-name='RedText'] => strong\n"
        "r[style-name='DeleteText'] => del"
    )
    
    script_dir = os.path.dirname(os.path.abspath(__file__))
    local_toml = os.path.join(source_folder, "style.toml")
    script_toml = os.path.join(script_dir, "style.toml")
    
    target_toml = None
    if os.path.exists(local_toml):
        target_toml = local_toml
    elif os.path.exists(script_toml):
        target_toml = script_toml
        
    if not target_toml:
        return default_mapping
        
    try:
        with open(target_toml, "rb") as f:
            data = tomllib.load(f)
            
        docx_config = data.get("docx", {})
        if not docx_config:
            return default_mapping
            
        mapping_lines = []
        
        # 兼容简易结构 [docx] 下直接写 KV (默认映射为 r)
        for k, v in docx_config.items():
            if isinstance(v, str):
                mapping_lines.append(f"r[style-name='{k}'] => {v}")
                
        # 支持 [docx.run]
        for k, v in docx_config.get("run", {}).items():
            mapping_lines.append(f"r[style-name='{k}'] => {v}")
            
        # 支持 [docx.paragraph]
        for k, v in docx_config.get("paragraph", {}).items():
            mapping_lines.append(f"p[style-name='{k}'] => {v}")
            
        if not mapping_lines:
            return default_mapping
            
        return "\n".join(mapping_lines)
        
    except Exception as e:
        print(f"[警告] 读取 {target_toml} 出错: {e}。将使用默认样式映射。")
        return default_mapping


def convert_docx_to_md(
    source_folder: str,
    target_folder: str,
    *,
    prefix: str = "",
    suffix: str = "",
    overwrite: bool = False,
):
    """
    遍历 source_folder 下 *.docx 并转换
    OVERWRITE_STRATEGY:
    • overwrite=True  -> 直接覆盖
    • overwrite=False -> 目标存在时自动在文件名后追加时间戳
    """
    docx_files = [f for f in os.listdir(source_folder) if f.lower().endswith('.docx')]

    try:
        from markitdown import MarkItDown
    except ImportError:
        raise RuntimeError("未找到 markitdown 库。请确保已安装 markitdown[docx] 并且在 Python 环境中可用。")

    if not docx_files:
        print("未找到 .docx 文件")
        return

    Path(target_folder).mkdir(parents=True, exist_ok=True)

    first_doc_path = os.path.join(source_folder, docx_files[0])
    common_info: FMData = prompt_common_front_matter(first_doc_path)
    
    style_mapping = get_style_mapping(source_folder)

    counter = 1
    for doc in docx_files:
        ep_str = get_episode_str(doc)
        if ep_str:
            file_num = ep_str
        else:
            file_num = f"{counter:02d}"
            counter += 1

        src_path = os.path.join(source_folder, doc)
        
        # 获取文件编辑日期 yymmdd
        try:
            mtime = os.stat(src_path).st_mtime
            date_str = datetime.datetime.fromtimestamp(mtime).strftime("%y%m%d")
        except Exception:
            date_str = datetime.datetime.now().strftime("%y%m%d")

        ctype = common_info.get('content_type', '')
        
        # 文件名：Prefix + 类型 + 集数/序列号 + Suffix + 时间.md
        base_name = f"{prefix}{ctype}{file_num}_{date_str}{suffix}"
        dst_name = f"{base_name}.md"
        dst_path = os.path.join(target_folder, dst_name)

        if os.path.exists(dst_path) and not overwrite:
            dup_idx = 1
            while True:
                dst_path = os.path.join(target_folder, f"{base_name}_{dup_idx:02d}.md")
                if not os.path.exists(dst_path):
                    break
                dup_idx += 1

        print(f"\n处理文件: {doc}")

        try:
            md = MarkItDown()
            
            result = md.convert(src_path, style_map=style_mapping)
            md_content = result.text_content
            this_info = common_info.copy()
            this_info['episode'] = file_num
            fm_text = build_front_matter(this_info)

            with open(dst_path, 'w', encoding='utf-8') as w:
                w.write(fm_text + md_content)
                
            print("✔ 已输出 ->", dst_path)

        except Exception as e:
            print("处理出错:", e)
            break

def main():
    parser = argparse.ArgumentParser(
        description="将 DOCX 批量转换为 Markdown，并交互式生成 front-matter"
    )
    parser.add_argument('source', nargs='?', default=os.getcwd(),
                        help="源文件夹 (默认: 当前目录)")
    parser.add_argument('target', nargs='?', default=os.path.join(os.getcwd(), 'md_output'),
                        help="目标文件夹 (默认: ./md_output)")
    parser.add_argument('--prefix', default="E", help="生成文件名前缀")
    parser.add_argument('--suffix', default="", help="生成文件名后缀")
    parser.add_argument('-f', '--overwrite', action='store_true',
                        help="若目标文件已存在则覆盖 (默认追加时间戳)")

    args = parser.parse_args()

    print("源目录 :", args.source)
    print("输出目录 :", args.target)
    
    convert_docx_to_md(args.source, args.target,
                       prefix=args.prefix,
                       suffix=args.suffix,
                       overwrite=args.overwrite)
    
if __name__ == "__main__":
    main()
